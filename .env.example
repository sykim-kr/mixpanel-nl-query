# === Railway 서버 환경변수 ===

# LLM Providers (최소 1개 필수)
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...

# 기본 LLM 프로바이더
LLM_PROVIDER=anthropic

# CORS: Vercel 프론트엔드 도메인 (콤마 구분 복수 가능)
CORS_ORIGIN=https://mixpanel-nl-query-3s3x.vercel.app

# 서버 포트 (Railway가 자동 설정)
PORT=3001

# Node 환경
NODE_ENV=production

# === Vercel 클라이언트 환경변수 ===
# VITE_API_URL=https://mixpanel-nl-query-production.up.railway.app
